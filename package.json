{
  "name": "mylinks",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface Env",
    "db-generate": "drizzle-kit generate",
    "wrangler:dev": "wrangler dev",
    "db:local:migrate": "wrangler d1 migrations apply DB --local",
    "db:local:query": "wrangler d1 execute DB --local --command",
    "db:local:studio": "drizzle-kit studio",
    "db:prod:migrate": "wrangler d1 migrations apply linkhub-prod",
    "db:local:reset": "rm -f .wrangler/state/v3/d1/miniflare-D1DatabaseObject/* && pnpm db:local:migrate",
    "db:test": "tsx scripts/test-db.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.10.0",
  "dependencies": {
    "@rive-app/react-canvas": "^4.23.3",
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/react-router": "^1.131.44",
    "@tanstack/react-start": "^1.131.44",
    "@tanstack/zod-adapter": "^1.131.44",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.13",
    "vite": "^7.1.5",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@types/node": "^24.5.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitejs/plugin-react": "^5.0.2",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.37.1"
  }
}