{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "linkhub",
	"main": ".output/server/index.mjs",
	"compatibility_date": "2025-09-16",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": ".output/public"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "linkhub-prod",
			"database_id": "f5ade111-b5ab-42c6-8d14-df3394449faa",
			"migrations_dir": "drizzle"
		}
	]
}